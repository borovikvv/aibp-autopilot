# ═══════════════════════════════════════════════════════════════════
# AIBP Autopilot — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill with real values. NEVER commit .env.

# ─── Telegram ───────────────────────────────────────────────────────
# Bot token from @BotFather. Bot must be admin in target channel.
TELEGRAM_BOT_TOKEN=

# Channel ID (with -100 prefix for supergroups/channels)
# Get from @userinfobot or @getidsbot after forwarding a message from the channel
TELEGRAM_CHANNEL_ID_PROD=-100XXXXXXXXXX

# Test channel for shadow experiments
TELEGRAM_CHANNEL_ID_TEST=-100XXXXXXXXXX

# Chat ID for alerts (your personal chat or private alert channel)
TELEGRAM_ALERT_CHAT_ID=

# Chat ID for engagement metrics collection (your personal chat with the bot).
# The bot copies channel posts here to read view counts, then deletes the copy.
# Without this, engagement collector falls back to getUpdates (limited, 409 risk).
# Get your chat_id by messaging @userinfobot after starting your bot.
TELEGRAM_METRICS_CHAT_ID=

# ─── Database ───────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://aibp:aibp@localhost:5432/aibp

# ─── LLM (OpenRouter) ───────────────────────────────────────────────
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Flagship model — post generation and ad creatives (the channel's product).
# Sonnet 5: $3/$15 per 1M tokens (intro $2/$10 through 2026-08-31).
OPENROUTER_MODEL=anthropic/claude-sonnet-5

# Model for self-learning pattern miner (weekly, 1 call — cost is negligible)
OPENROUTER_MINER_MODEL=anthropic/claude-sonnet-5

# Cheap model for high-volume RSS classification (up to ~360 calls/day) when
# routed via OpenRouter (i.e. OPENCODE_API_KEY is empty).
# DeepSeek V4 Flash: ~$0.09/$0.18 per 1M tokens — ~30x cheaper than Sonnet.
OPENROUTER_ENRICHMENT_MODEL=deepseek/deepseek-v4-flash

# Cheap model for "same news story?" dedup checks (binary JSON answer)
OPENROUTER_DEDUP_MODEL=deepseek/deepseek-v4-flash

# OpenAI-compatible gateway base URL for flagship calls (generation, miner,
# creatives, images, embeddings).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── opencode zen — second gateway for cheap tasks (optional) ───────
# When OPENCODE_API_KEY is set, enrichment + dedup route through opencode zen
# (flat subscription pricing) with OPENCODE_MODEL, while Sonnet keeps going
# through OpenRouter. Leave the key empty to run everything via OpenRouter.
# Get the key at https://opencode.ai/zen (note: zen model ids have no
# provider prefix — "deepseek-v4-flash", not "deepseek/deepseek-v4-flash").
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash

# Daily budget limit in USD (safety guard)
OPENROUTER_DAILY_BUDGET_USD=5.00

# Embeddings (issue #40) — competitor dedup. OpenAI-compatible /api/v1/embeddings.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ─── Image Generation (xAI Grok, legacy/unused) ─────────────────────
# Get key at https://x.ai/api
XAI_API_KEY=

# ─── Post image generation via OpenRouter (issue #34) ───────────────
# Used when visual_policy.enabled + visual_policy.generate. IMAGE_OUTPUT_DIR
# must be web-served at IMAGE_PUBLIC_BASE_URL so Telegram can fetch the image.
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENROUTER_IMAGE_COST_USD=0.04
IMAGE_OUTPUT_DIR=/srv/static/aibp/img
IMAGE_PUBLIC_BASE_URL=https://cockpit.borovikvv.ru/aibp/img

# ─── Hermes Agent ───────────────────────────────────────────────────
# Hermes API base URL (optional, only needed for cron registration)
HERMES_API_URL=https://hermes-agent.nousresearch.com

# ─── Application ────────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=production

# Timezone for all cron schedules
APP_TIMEZONE=Europe/Moscow

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to policy.yaml (canonical self-learning config)
POLICY_PATH=config/policy.yaml

# Path to RSS feeds list
RSS_FEEDS_PATH=config/rss_feeds.yaml

# ─── Web Dashboard (optional) ───────────────────────────────────────
# Caddy-served static dashboard path
DASHBOARD_OUTPUT_PATH=/srv/static/aibp/dashboard.html
DASHBOARD_BASE_URL=https://cockpit.borovikvv.ru/aibp

# ─── Click tracking (issue #15, optional) ───────────────────────────
# Public base URL of the redirect service. Empty = link wrapping disabled.
# Posts will use TRACKING_BASE_URL/r/{short_id} instead of direct source URLs.
TRACKING_BASE_URL=
TRACKING_PORT=8091

# ─── Growth monitoring (issue #19, optional) ────────────────────────
# TGStat API token for competitor analytics (config/competitors.yaml).
# Without it the weekly growth report covers only own subscriber dynamics.
TGSTAT_API_TOKEN=

# ─── Competitor scraping (issue #40, optional) ───────────────────────
# Firecrawl API key for fetching competitor channel content.
# Without it competitor scraping falls back to a plain HTTP fetch.
FIRECRAWL_API_KEY=
